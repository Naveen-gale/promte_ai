# Example environment variables for the backend
# Rename to .env and load with python-dotenv, or set directly on Render

# Directory where adapter files (adapter_config.json, adapter_model.safetensors,
# tokenizer.json, tokenizer_config.json) are stored.
# On Render this defaults automatically to the repo root.
# ADAPTER_DIR=/opt/render/project/src

# HuggingFace base model (downloaded at startup)
# BASE_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# Comma-separated list of allowed CORS origins (your Vercel domain)
# CORS_ORIGINS=https://your-app.vercel.app

# Port (Render sets this automatically — do not change)
# PORT=5000
